# ═══════════════════════════════════════════════════════════════
# NEXUS TRADER — Environment Variables
# Copy this file to .env and fill in your real values
# ═══════════════════════════════════════════════════════════════

# ── DERIV API ────────────────────────────────────────────────
# Generate at: https://app.deriv.com/account/api-token
# Permissions needed: Read, Trade
DERIV_APP_ID=1089
DERIV_API_TOKEN_DEMO=your_demo_api_token_here
DERIV_API_TOKEN_REAL=your_real_api_token_here
DERIV_WS_URL=wss://ws.binaryws.com/websockets/v3

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ── SECURITY ─────────────────────────────────────────────────
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
ADMIN_PASSWORD=change_this_password

# ── ACCOUNT MODE ─────────────────────────────────────────────
# Start with demo, switch to real when confident
DEFAULT_ACCOUNT_MODE=demo

# ── TRADING DEFAULTS ─────────────────────────────────────────
DEFAULT_STAKE=10
DEFAULT_DURATION=5t
DEFAULT_MIN_CONFIDENCE=70
DEFAULT_TARGET_PROFIT=100
DEFAULT_STOP_LOSS=50

# ── RISK MANAGEMENT ──────────────────────────────────────────
MAX_DAILY_LOSS=200
MAX_DAILY_PROFIT=1000
MAX_CONSECUTIVE_LOSSES=5
MAX_STAKE_REAL=50
MAX_STAKE_DEMO=500
MARTINGALE_MULTIPLIER=2.0
MARTINGALE_MAX_STEPS=4

# ── AUTO-TRADE ───────────────────────────────────────────────
AUTO_TRADE_ENABLED=false
AUTO_TRADE_MARKETS=R_10,R_25,R_75
BOT_SCAN_INTERVAL_MS=15000
SIGNAL_SCAN_INTERVAL_MS=20000
ANALYSIS_INTERVAL_MS=2000

# ── MARKETS TO MONITOR ───────────────────────────────────────
MONITOR_MARKETS=R_10,R_25,R_50,R_75,R_100,CRASH500,BOOM500,CRASH1000,BOOM1000,stpRNG,JD10,JD25,frxEURUSD,frxGBPUSD,frxUSDJPY,frxAUDUSD,frxUSDCAD,frxEURGBP,frxXAUUSD,frxXAGUSD

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIR=./logs

# ── OPTIONAL: TELEGRAM ALERTS ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
